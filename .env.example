# ============================================
# RandomBeast Environment Configuration
# ============================================

# Environment
NODE_ENV=production

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://randombeast:YOUR_DB_PASSWORD@localhost:5432/randombeast?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# ============================================
# Telegram Bot
# ============================================
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
# TMA_BOT_TOKEN используется для валидации initData в Mini App (обычно = BOT_TOKEN)
TMA_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_USERNAME=BeastRandomBot
# Режим работы бота: polling (dev) или webhook (production)
BOT_MODE=polling
# Секрет для верификации webhook запросов от Telegram
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_WEBHOOK_SECRET=GENERATE_RANDOM_64_CHAR_HEX_STRING
# Прокси для Telegram API (Cloudflare Worker) — если хостер блокирует/замедляет TLS к api.telegram.org
# TELEGRAM_API_ROOT=https://your-tg-proxy.your-account.workers.dev

# ============================================
# URLs (Production)
# ============================================
# Web App (Telegram Mini App)
WEBAPP_URL=https://app.randombeast.ru

# API Server
API_URL=https://api.randombeast.ru

# Marketing Site
SITE_URL=https://randombeast.ru

# ============================================
# Порты (для dev, в production используются reverse proxy)
# ============================================
API_PORT=4000
WEB_PORT=3000
SITE_PORT=3001

# ============================================
# Frontend URLs (для клиентского кода Next.js)
# ============================================
NEXT_PUBLIC_API_URL=https://api.randombeast.ru/api/v1
NEXT_PUBLIC_SITE_URL=https://randombeast.ru
NEXT_PUBLIC_WEBAPP_URL=https://app.randombeast.ru
NEXT_PUBLIC_BOT_USERNAME=BeastRandomBot

# ============================================
# Security (ОБЯЗАТЕЛЬНО ИЗМЕНИТЬ В PRODUCTION!)
# ============================================
# Минимум 32 символа, сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERATE_RANDOM_64_CHAR_HEX_STRING
SESSION_SECRET=GENERATE_RANDOM_64_CHAR_HEX_STRING
INTERNAL_API_TOKEN=GENERATE_RANDOM_32_CHAR_STRING

# Cookie domain для shared cookies между поддоменами
COOKIE_DOMAIN=.randombeast.ru

# ============================================
# YooKassa Payment
# ============================================
YOOKASSA_SHOP_ID=YOUR_SHOP_ID
YOOKASSA_SECRET_KEY=YOUR_SECRET_KEY
YOOKASSA_RETURN_URL=https://app.randombeast.ru/payments/return
# Секрет для верификации webhook от YooKassa
YOOKASSA_WEBHOOK_SECRET=YOUR_YOOKASSA_WEBHOOK_SECRET

# ============================================
# Sentry Error Tracking
# ============================================
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production

# ============================================
# Admin & Promo
# ============================================
# Telegram Chat ID для отправки проактивных уведомлений администратору
# Это может быть личный чат (user ID) или ID канала/группы
# Узнать ID: перешлите сообщение боту @userinfobot
ADMIN_CHAT_ID=123456789
# Telegram User IDs администраторов (через запятую) — для бот-команд /admin_ban, /admin_stats
ADMIN_USER_IDS=123456789,987654321
# Промо-канал бота
# PROMO_CHANNEL_USERNAME=randombeast_news
# PROMO_CHANNEL_URL=https://t.me/randombeast_news

# ============================================
# Limits & Captcha
# ============================================
# Максимальный размер загружаемого файла (МБ)
MAX_FILE_SIZE_MB=50
# Время жизни капчи (секунды)
CAPTCHA_TTL_SECONDS=120
# Максимум попыток капчи
CAPTCHA_MAX_ATTEMPTS=3
# Сколько дней хранить фото Liveness Check
LIVENESS_PHOTO_RETENTION_DAYS=30

# ============================================
# Cloudflare Turnstile (для режима капчи «Для всех»)
# ============================================
# Получить на https://dash.cloudflare.com → Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ============================================
# Кастомные эмодзи для кнопок (Telegram Premium)
# ============================================
# Требуется: Telegram Premium у владельца бота
# Получить ID: отправьте кастомный эмодзи боту (команда /emoji_id)
# Управление: /emoji_status, /emoji_enable, /emoji_disable
CUSTOM_EMOJI_ENABLED=true

# ID кастомных эмодзи для кнопок бота (inline + reply)
# Розовые (danger) — основные действия:
EMOJI_APP=                # 📱 «Открыть приложение» (inline + reply)
EMOJI_CREATE=             # 🎁 «Создать розыгрыш» (inline + reply)
EMOJI_CHANNELS=           # 📣 «Мои каналы» (reply)
EMOJI_POSTS=              # 📝 «Посты» (reply)
EMOJI_SETTINGS=           # ⚙️ «Настройки» (reply)
EMOJI_SUPPORT=            # 🆘 «Поддержка» (reply)
EMOJI_JOIN=               # 🎁 «Участвовать»
EMOJI_BUY=                # ⭐ «Купить подписку»
EMOJI_ADD=                # ➕ «Добавить канал/группу»
EMOJI_DELETE=             # 🗑 «Удалить»
EMOJI_CONFIRM=            # ✅ «Подтвердить публикацию»
EMOJI_STATS=              # 📊 «Открыть статистику»
EMOJI_RESULTS=            # 🏆 «Результаты»
EMOJI_WINNERS=            # 🎯 «Выбрать победителей»
EMOJI_SUBSCRIBE=          # 💳 «Подписка»
EMOJI_UNDO=               # ↩️ «Отменить удаление»
EMOJI_CREATE_BOT=         # 🤖 «В боте (скоро)»
# Синие (primary) — навигация / настройки:
EMOJI_BACK=               # ◀️ «Назад» (inline + reply)
EMOJI_HOME=               # 🏠 «В меню» (inline + reply)
EMOJI_CANCEL=             # ❌ «Отмена»
EMOJI_REJECT=             # ✖️ «Отклонить публикацию»
EMOJI_LANG_RU=            # 🇷🇺 Флаг «Русский»
EMOJI_LANG_EN=            # 🇬🇧 Флаг «English»
EMOJI_LANG_KK=            # 🇰🇿 Флаг «Қазақша»
EMOJI_NOTIF=              # 📢 Секция «Уведомления»
EMOJI_NOTIF_MILESTONE=    # 🎯 Режим «Вехи»
EMOJI_NOTIF_DAILY=        # 📅 Режим «Ежедневно»
EMOJI_NOTIF_OFF=          # 🔕 Режим «Выкл»

# ============================================
# Режим разработки (опционально)
# ============================================
# Пароль для доступа к сайту (если пусто — сайт открыт)
# MAINTENANCE_PASSWORD=your_secret_password

# Whitelist Telegram ID для бота и Mini App (через запятую)
# Если пусто — доступ для всех
# ALLOWED_USERS=123456789,987654321
